<resources>
    <!--
      Post-splash window theme. Colors at runtime come from the Compose `FilmatubeTheme`;
      this only sets the window chrome (forced-dark green background, transparent system bars
      for edge-to-edge).
    -->
    <style name="Theme.Filmatube" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/filmatube_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!--
      Launch theme using the AndroidX SplashScreen API. Shows the Filmatube mark on a
      dark green background, then hands off to Theme.Filmatube. (The richer animated splash
      is Day 15.)
    -->
    <style name="Theme.Filmatube.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/filmatube_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Filmatube</item>
    </style>
</resources>
