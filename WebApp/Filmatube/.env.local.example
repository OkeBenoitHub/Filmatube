# Copy to `.env.local` and fill in. `.env.local` is git-ignored.

# --- Firebase Web (client) ---
# Firebase console > Project settings > General > Your apps > Web app > SDK setup & config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=filmatubelive
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin (server) ---
# Firebase console > Project settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=filmatubelive
FIREBASE_CLIENT_EMAIL=
# Paste the whole private key on one line with literal \n for newlines, wrapped in quotes:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# --- Cloudflare R2 ---
# Dashboard > R2 > Manage R2 API Tokens (Object Read & Write). See infra/r2/README.md
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_VIDEOS=filmatube-videos
R2_BUCKET_IMAGES=filmatube-images
R2_BUCKET_AVATARS=filmatube-avatars
R2_BUCKET_SUBTITLES=filmatube-subtitles
# Public base URL PER public bucket (each bucket has its own pub-*.r2.dev or custom domain).
# `videos` is private (served via /api/stream), so it has no public URL.
R2_PUBLIC_URL_IMAGES=
R2_PUBLIC_URL_AVATARS=
R2_PUBLIC_URL_SUBTITLES=
