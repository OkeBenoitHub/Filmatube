rules_version = '2';

// Filmatube security rules v1 (movies-only).
// Principles: everything requires sign-in; users own their subtrees; catalog is
// admin-written; the `admin` custom claim (not the users doc) is authoritative.
// Final hardening audit is scheduled for Days 117/122.
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────── helpers ─────────
    // A banned user is treated as not signed in at all. Every other rule builds on this
    // (isSelf/isAdmin included), so one check here denies a banned account every read and
    // write in the ruleset. `banned` is a custom CLAIM, not a users-doc field — a user can't
    // grant themselves a claim, and setting it revokes their refresh tokens so the next token
    // refresh (<= 1h, immediate on re-auth) locks them out.
    function isBanned() {
      return request.auth.token.get('banned', false) == true;
    }
    function isSignedIn() {
      return request.auth != null && !isBanned();
    }
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ───────── users ─────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId)
        && request.resource.data.get('isAdmin', false) == false
        && request.resource.data.get('isBanned', false) == false;
      allow update: if isAdmin()
        || (isSelf(userId)
          && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false)
          && request.resource.data.get('isBanned', false) == resource.data.get('isBanned', false));
      allow delete: if isAdmin();

      match /profiles/{profileId} {
        allow read, write: if isSelf(userId) || isAdmin();
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isSelf(userId);
        // A signed-in actor may write a notification into a recipient's inbox, but must
        // stamp their own uid as actor and may NOT forge a `system` (broadcast) notification —
        // those are written only by the admin/Cloud-Function server (which bypasses rules).
        allow create: if isSignedIn()
          && request.resource.data.actorId == request.auth.uid
          && request.resource.data.type != 'system';
      }

      match /fcmTokens/{tokenId} {
        allow read, write: if isSelf(userId);
      }

      // per-user settings (e.g. notification channel opt-in) — a Cloud Function honors these when sending push
      match /settings/{settingId} {
        allow read, write: if isSelf(userId);
      }
    }

    // ───────── catalog ─────────
    match /movies/{movieId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.status == 'published');
      allow write: if isAdmin();
    }

    // ───────── per-user viewing state ─────────
    match /watchProgress/{userId}/items/{movieId} {
      allow read, write: if isSelf(userId);
    }
    match /watchlists/{userId}/movies/{movieId} {
      allow read, write: if isSelf(userId);
    }
    match /likes/{userId}/items/{movieId} {
      allow read: if isSignedIn();
      allow write: if isSelf(userId);
    }
    match /reactions/{userId}/items/{movieId} {
      allow read: if isSignedIn();
      allow write: if isSelf(userId);
    }

    // ───────── collections ─────────
    match /collections/{collectionId} {
      allow read: if isAdmin()
        || (isSignedIn() && (resource.data.isPublic == true || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      match /items/{movieId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn()
          && get(/databases/$(database)/documents/collections/$(collectionId)).data.userId == request.auth.uid;
      }
    }

    // ───────── social graph ─────────
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid
        && followId == (request.auth.uid + '_' + request.resource.data.followedId);
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    match /feed/{userId}/events/{eventId} {
      allow read: if isSelf(userId);
      // fan-out: the actor may write their own event into a follower's feed
      allow create: if isSignedIn() && request.resource.data.actorId == request.auth.uid;
      allow delete: if isSelf(userId);
    }

    match /recommendations/{toUserId}/items/{recommendationId} {
      allow read, update, delete: if isSelf(toUserId);
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
    }

    // ───────── ratings (1–5 stars, one per user per movie) ─────────
    // Aggregation into movies/{id}.averageRating/ratingsCount is done by a Cloud Function
    // (functions/index.js); clients may also compute a live average by reading this subtree.
    match /ratings/{movieId}/items/{userId} {
      allow read: if isSignedIn();
      allow write: if isSelf(userId);
    }

    // ───────── reviews & comments ─────────
    match /reviews/{movieId}/items/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // review likes — one doc per user, keyed by uid; count derived by reading the subtree
      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isSelf(userId);
      }
    }
    match /comments/{movieId}/items/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // comment likes — one doc per user, keyed by uid; count derived by reading the subtree
      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isSelf(userId);
      }
    }

    // ───────── moderation reports (reviews/comments) ─────────
    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ───────── admin broadcasts (processed server-side / by a Cloud Function) ─────────
    match /broadcasts/{broadcastId} {
      allow read, write: if isAdmin();
    }

    // ───────── server-only rate-limit counters (admin SDK bypasses rules) ─────────
    match /rateLimits/{id} {
      allow read, write: if false;
    }

    // ───────── community boards (v1.1) ─────────
    match /boards/{boardId} {
      allow read: if isSignedIn() && (
        resource.data.isPublic == true
        || resource.data.ownerId == request.auth.uid
        || request.auth.uid in resource.data.memberIds
      );
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      // Owner/admin may edit the board; any signed-in user may join/leave — a membership-only
      // update (memberIds + memberCount) that adds or removes *their own* uid.
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid)
        || (isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberCount'])
          && (
            (!(request.auth.uid in resource.data.memberIds) && request.auth.uid in request.resource.data.memberIds)
            || (request.auth.uid in resource.data.memberIds && !(request.auth.uid in request.resource.data.memberIds))
          ));

      function isBoardOwner() {
        return isSignedIn()
          && get(/databases/$(database)/documents/boards/$(boardId)).data.ownerId == request.auth.uid;
      }
      function canPost() {
        return exists(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid)).data.get('muted', false) == false;
      }

      match /members/{userId} {
        allow read: if isSignedIn();
        allow create: if isSelf(userId);
        // Self can update/leave; the board owner (or admin) can mute/remove any member.
        allow update, delete: if isSelf(userId) || isAdmin() || isBoardOwner();
      }
      match /messages/{messageId} {
        allow read: if isSignedIn();
        // Only non-muted members may post.
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && canPost();
        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.userId == request.auth.uid)
          || isBoardOwner();
        // Author may edit their message; anyone signed-in may toggle a reaction (reactions map only).
        allow update: if isAdmin()
          || (isSignedIn() && resource.data.userId == request.auth.uid)
          || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']));
      }
      match /typing/{userId} {
        allow read: if isSignedIn();
        allow write: if isSelf(userId);
      }
    }

    // ───────── watch parties (private: host + invited guests) ─────────
    match /parties/{partyId} {
      // Private by design: only members (or the host) can even read the party.
      allow read: if isSignedIn() && (
        resource.data.hostId == request.auth.uid
        || request.auth.uid in resource.data.memberIds
      );
      allow create: if isSignedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.status == 'scheduled';
      allow delete: if isAdmin() || (isSignedIn() && resource.data.hostId == request.auth.uid);
      // Host edits anything (start/end, reschedule); anyone signed-in may make a
      // membership-only change that toggles their own uid (accepting an invite).
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.hostId == request.auth.uid)
        || (isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberCount'])
          && (
            (request.auth.uid in request.resource.data.memberIds && !(request.auth.uid in resource.data.memberIds))
            || (!(request.auth.uid in request.resource.data.memberIds) && request.auth.uid in resource.data.memberIds)
          ));

      function isPartyHost() {
        return get(/databases/$(database)/documents/parties/$(partyId)).data.hostId == request.auth.uid;
      }
      function isPartyMember() {
        return exists(/databases/$(database)/documents/parties/$(partyId)/members/$(request.auth.uid));
      }

      match /members/{userId} {
        allow read: if isSignedIn() && (isPartyMember() || isPartyHost());
        allow create: if isSelf(userId);
        allow update, delete: if isSelf(userId) || isAdmin() || (isSignedIn() && isPartyHost());
      }

      // The sync engine: HOST is the single writer; members read.
      match /sync/{docId} {
        allow read: if isSignedIn() && (isPartyMember() || isPartyHost());
        allow write: if isSignedIn() && isPartyHost();
      }

      // Floating chat during playback — members only, author stamps their own uid.
      match /messages/{messageId} {
        allow read: if isSignedIn() && (isPartyMember() || isPartyHost());
        allow create: if isSignedIn() && isPartyMember()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.userId == request.auth.uid)
          || (isSignedIn() && isPartyHost());
        allow update: if false;
      }

      // Ephemeral floating emoji — write-once, never edited.
      match /reactions/{reactionId} {
        allow read: if isSignedIn() && (isPartyMember() || isPartyHost());
        allow create: if isSignedIn() && isPartyMember()
          && request.resource.data.userId == request.auth.uid;
        allow update: if false;
        allow delete: if isAdmin() || (isSignedIn() && isPartyHost());
      }
    }

    // ───────── content requests ─────────
    match /requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // ───────── gamification ─────────
    match /achievements/{userId}/badges/{badgeId} {
      allow read: if isSignedIn();
      allow write: if isSelf(userId) || isAdmin();
    }
    match /stats/{userId} {
      allow read: if isSignedIn();
      allow write: if isSelf(userId) || isAdmin();
    }

    // ───────── online movie theater (v1.2 — reserved) ─────────
    match /showtimes/{showtimeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /attendees/{userId} {
        allow read: if isSignedIn();
        allow write: if isSelf(userId);
      }
      match /chat/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }
  }
}
